@echo off
title Запуск системы определения настроения

:: Активация Anaconda (путь может отличаться — проверь свой!)
call E:\anaconda\Scripts\activate.bat base

:: Переход в папку проекта
cd /d E:\diplom_ser

:: Запуск сервера в фоне и открытие браузера
start python app.py

:: Ждём 3 секунды, чтобы сервер успел запуститься
timeout /t 3 /nobreak

:: Открываем сайт в браузере по умолчанию
start http://127.0.0.1:5000

echo Система запущена! Не закрывай это окно, пока работаешь с сайтом.
pause